{
  "expo": {
    "name": "Hey Dad",
    "slug": "heydad-mobile",
    "scheme": "com.heydad",
    "version": "1.0.5",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.870176413610-b0nq2pnugvk0u89h36tbf12t80vrkrm2"
        }
      ],
      "expo-iap",
      "expo-web-browser"
    ],
    "ios": {
      "buildNumber": "2",
      "icon": "./assets/icon.png",
      "usesAppleSignIn": true,
      "supportsTablet": false,
      "bundleIdentifier": "com.heydadllc.heydad",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Hey Dad needs access to your camera to create your photo and video stories.",
        "NSMicrophoneUsageDescription": "Hey Dad needs access to your microphone to record your audio stories."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.hey.dad"
    },
    "owner": "justinheydad",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe8cb946-747a-4a9d-b398-b436dc40b908"
      }
    }
  }
}
